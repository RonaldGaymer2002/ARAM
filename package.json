{
  "name": "decouple-services",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:vercel": "node scripts/vercel-build.mjs web",
    "build:vercel:fundares": "node scripts/vercel-build.mjs fundares",
    "dev": "turbo run dev",
    "dev:identification": "npm --prefix apps/identification run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
