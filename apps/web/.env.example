# Neon Postgres (from Neon dashboard → Connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Vercel Blob (Vercel dashboard → Storage → Blob → token)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key

# Google Cloud Vision (optional OCR)
GOOGLE_VISION_API_KEY=your-google-vision-key

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Webhook security
WEBHOOK_SECRET=your-random-secret-here

# App URL (production URL on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_WEBHOOK_SECRET=random-secret-string

# Seed admin (only for scripts/seed-admin.mjs)
ADMIN_EMAIL=admin@fundares.org
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrador
